#!/usr/bin/env bash

all=false

while getopts ":a" opt; do
	case "$opt" in
		a) all=true ;;
		\?)
			echo "Invalid option: -$OPTARG"
			exit 1
			;;
	esac
done

shift $((OPTIND - 1))

SOCK="/run/sshu/agent.sock"
SSH_DIR="/home/sshu/.ssh"

if [[ ! $all ]]; then
	if [[ "$#" -ne 1 ]] || [[ "$1" == "help" ]] || [[ "$1" == "?" ]]; then
		echo "Usage: sshu-up \"name\""
		exit 1
	fi
else
	if [[ "$#" -ne 0 ]]; then
		echo "\"sshu-up -a\" does not take arguments"
		exit 1
	fi
	SSH_AUTH_SOCK="$SOCK" ssh-add -D
fi

name="$1"

KEY="$SSH_DIR/$name"
CONFIG="$SSH_DIR/config"

if [[ ! -f "$KEY" ]]; then
	echo "No key with name: \"$name\" found"
	exit 1
fi

SSH_AUTH_SOCK="$SOCK" ssh-add -d "$KEY"
